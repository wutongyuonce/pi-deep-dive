#!/bin/sh
# =============================================================================
# Git Pre-commit Hook（提交前钩子）
# =============================================================================
#
# 这是什么：
# - 这是一个 Git hook，在你执行 `git commit` 时自动触发
# - Husky 是一个 npm 包，让 Git hook 的管理更方便（不用手动放到 .git/hooks/ 目录）
#
# 作用：
# - 在代码提交到 Git 仓库之前，自动运行一系列检查
# - 如果任何检查失败，阻止提交，强制你先修复问题
# - 这保证了仓库中的代码始终是"通过检查的"
#
# 触发时机：
# - 你执行 `git commit` 时
# - 在 commit message 编辑之前执行
# - 如果脚本返回非 0 退出码，commit 被取消
#
# 谁管理这个文件：
# - Husky（https://typicode.github.io/husky/）
# - 这个文件会被 Git 追踪，团队共享，所有人都用同一套检查规则
# =============================================================================

# -----------------------------------------------------------------------------
# 第一步：记录当前已暂存（staged）的文件列表
# -----------------------------------------------------------------------------
# git diff --cached --name-only：列出所有已暂存（等待提交）的文件路径
# 例如：packages/ai/src/types.ts packages/agent/src/agent.ts
# 保存到变量 STAGED_FILES，后面会用到
STAGED_FILES=$(git diff --cached --name-only)

# -----------------------------------------------------------------------------
# 第二步：检查 lockfile 是否被意外修改
# -----------------------------------------------------------------------------
# 运行 scripts/check-lockfile-commit.mjs 脚本
# 这个脚本检查 package-lock.json 是否被正确处理
# （lockfile 变更需要特殊审批，防止意外修改依赖版本）
node scripts/check-lockfile-commit.mjs

# $? 是上一个命令的退出码：0 表示成功，非 0 表示失败
# -ne 是 "not equal"（不等于）
# 如果退出码不是 0（检查失败），终止提交
if [ $? -ne 0 ]; then
  exit 1  # 退出码 1 表示失败，Git 会取消 commit
fi

# -----------------------------------------------------------------------------
# 第三步：运行格式化、lint 和类型检查
# -----------------------------------------------------------------------------
# npm run check 通常包含：
# - 代码格式化检查（如 Prettier）
# - 代码风格检查（如 ESLint）
# - TypeScript 类型检查（tsc --noEmit）
echo "Running formatting, linting, and type checking..."
npm run check

# 如果检查失败，打印错误信息并终止提交
if [ $? -ne 0 ]; then
  echo "❌ Checks failed. Please fix the errors before committing."
  exit 1
fi

# -----------------------------------------------------------------------------
# 第四步：条件性地运行浏览器冒烟测试
# -----------------------------------------------------------------------------
# 初始化标志变量：是否需要运行浏览器冒烟测试
# 0 = 不需要，1 = 需要
RUN_BROWSER_SMOKE=0

# 遍历所有已暂存的文件
for file in $STAGED_FILES; do
  # case 语句类似 switch，用模式匹配文件路径
  case "$file" in
    # 如果文件在 packages/ai/、packages/web-ui/ 目录下，
    # 或者是 package.json / package-lock.json
    # 则设置标志为 1（需要运行冒烟测试）
    packages/ai/*|packages/web-ui/*|package.json|package-lock.json)
      RUN_BROWSER_SMOKE=1
      break  # 找到一个匹配就跳出循环，不需要继续检查
      ;;
  esac
done

# 如果标志为 1，运行浏览器冒烟测试
# 这个测试验证包在浏览器环境中能正常工作
if [ $RUN_BROWSER_SMOKE -eq 1 ]; then
  echo "Running browser smoke check..."
  npm run check:browser-smoke

  if [ $? -ne 0 ]; then
    echo "❌ Browser smoke check failed."
    exit 1
  fi
fi

# -----------------------------------------------------------------------------
# 第五步：重新暂存可能被格式化工具修改的文件
# -----------------------------------------------------------------------------
# 为什么需要这一步：
# - npm run check 中的格式化工具可能会自动修复代码格式
# - 修复后的文件变成了"已修改但未暂存"的状态
# - 如果不重新暂存，commit 的内容会和磁盘上的不一致
# - 所以这里把之前暂存的文件重新 add 一次
for file in $STAGED_FILES; do
  # -f 检查文件是否存在（有些文件可能被删除了）
  if [ -f "$file" ]; then
    git add "$file"  # 重新暂存
  fi
done

# 所有检查通过，打印成功信息
echo "✅ All pre-commit checks passed!"
# 脚本正常结束（退出码 0），Git 继续执行 commit
