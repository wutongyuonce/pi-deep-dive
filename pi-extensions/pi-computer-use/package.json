{
	"name": "@injaneity/pi-computer-use",
	"version": "0.5.0",
	"description": "Pi extension that lets AI agents observe and control macOS and Windows apps.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"computer-use",
		"macos",
		"desktop-automation",
		"accessibility"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/injaneity/pi-computer-use.git"
	},
	"bugs": {
		"url": "https://github.com/injaneity/pi-computer-use/issues"
	},
	"homepage": "https://github.com/injaneity/pi-computer-use#readme",
	"engines": {
		"node": ">=20.6.0"
	},
	"files": [
		"extensions",
		"src",
		"scripts/build-native.mjs",
		"scripts/setup-helper.mjs",
		"native/macos/bridge.swift",
		"native/windows/bridge-rs/Cargo.lock",
		"native/windows/bridge-rs/Cargo.toml",
		"native/windows/bridge-rs/src",
		"native/windows/bridge-rs/tests",
		"prebuilt/macos",
		"prebuilt/windows",
		"assets/reference/img.jpg",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./extensions"
		],
		"image": "./assets/reference/img.jpg"
	},
	"scripts": {
		"postinstall": "node scripts/setup-helper.mjs --postinstall",
		"typecheck": "tsc -p tsconfig.json",
		"test:schema": "node scripts/check-tool-schemas.mjs",
		"test:invariants": "node scripts/check-invariants.mjs",
		"test:lifecycle": "node --experimental-transform-types scripts/check-session-lifecycle.mjs",
		"test:runtime": "node --experimental-transform-types scripts/check-runtime-concurrency.mjs",
		"test:output": "node --experimental-transform-types scripts/check-bounded-output.mjs",
		"test:commits": "node scripts/check-commit-messages.mjs",
		"test:platform": "node --experimental-strip-types scripts/check-platform-windows.mjs",
		"test:windows-scripts": "node scripts/check-windows-build-scripts.mjs",
		"test:signing": "node scripts/check-local-signing.mjs",
		"test:macos-path": "node scripts/check-macos-helper-path.mjs",
		"test": "npm run typecheck && npm run test:schema && npm run test:output && npm run test:lifecycle && npm run test:runtime && npm run test:invariants && npm run test:signing && npm run test:macos-path",
		"build:native": "node scripts/build-native.mjs",
		"build:windows": "node scripts/build-native.mjs --platform windows"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3"
	}
}
